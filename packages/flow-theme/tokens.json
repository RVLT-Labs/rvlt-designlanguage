{
  "$comment": "RVLT Flow — single source of truth for theme tokens. Mirrors DESIGN.md §3/§5/§7 + Appendix A. globals.css is GENERATED from this file (scripts/build-css.mjs) — never hand-edit dist/globals.css.",
  "version": "0.1.0",
  "designSpec": "DESIGN.md v1.1.1",
  "defaultTheme": "dark",
  "themes": {
    "dark": {
      "paper": "#141210", "paper-2": "#1A1613", "card": "#211C17", "elev": "#2A241D",
      "ink": "#F5EFE2", "ink-2": "#CDC4B2", "muted": "#9E9483", "faint": "#6E665A",
      "line": "#332C24", "line-2": "#473E32",
      "red": "#E0363D", "red-700": "#B21F26", "red-soft": "rgba(224,54,61,.16)",
      "ok": "#4FD888", "warn": "#EBA53A", "rep": "#B6AC9A", "t-out": "#F26F73",
      "ok-soft": "rgba(62,207,122,.14)", "warn-soft": "rgba(235,165,58,.15)",
      "rep-soft": "rgba(158,148,131,.14)", "out-soft": "rgba(224,54,61,.18)",
      "amber": "#EBA53A", "blue": "#5B8DEF", "green": "#3ECF7A", "purple": "#9B82E6", "dark": "#0E0C0A",
      "coral": "#EF7E55", "teal": "#3FC8BE", "pink": "#E875AC", "lime": "#AFC44E",
      "blue-soft": "rgba(91,141,239,.15)", "amber-soft": "rgba(235,165,58,.15)",
      "green-soft": "rgba(62,207,122,.14)", "purple-soft": "rgba(155,130,230,.15)",
      "coral-soft": "rgba(239,126,85,.15)", "teal-soft": "rgba(63,200,190,.15)",
      "scrim": "rgba(14,12,10,.66)", "select": "rgba(224,54,61,.20)", "link": "#5B8DEF",
      "sh-card": "0 3px 0 #0C0A08", "sh-hover": "0 7px 0 #0C0A08",
      "lit": "inset 0 1px 0 rgba(255,253,248,.14)", "sh-stk": "2px 4px 0 rgba(0,0,0,.5)"
    },
    "light": {
      "paper": "#F4EEE1", "paper-2": "#EDE4D2", "card": "#FFFDF8", "elev": "#FFFDF8",
      "ink": "#1D1A15", "ink-2": "#4B4539", "muted": "#7D7565", "faint": "#A89E89",
      "line": "#E4DAC3", "line-2": "#D8CCB0",
      "red": "#C12229", "red-700": "#9C1B21", "red-soft": "#FBE7E3",
      "ok": "#2EA65C", "warn": "#C98A14", "rep": "#8A8270", "t-out": "#9C1B21",
      "ok-soft": "#E7F5EC", "warn-soft": "#FBF0D6", "rep-soft": "#EFE9DC", "out-soft": "#FBE7E3",
      "amber": "#E79A2B", "blue": "#2F6BD6", "green": "#2EA65C", "purple": "#7A5CD0", "dark": "#241F1A",
      "coral": "#CC5E2E", "teal": "#1C8B83", "pink": "#C2487E", "lime": "#6E8C12",
      "blue-soft": "#E2ECFB", "amber-soft": "#FBF0D6", "green-soft": "#E7F5EC",
      "purple-soft": "#ECE6FA", "coral-soft": "#FBE6DB", "teal-soft": "#DBF1EF",
      "scrim": "rgba(40,30,15,.45)", "select": "rgba(193,34,41,.16)", "link": "#2F6BD6",
      "sh-card": "0 3px 0 var(--line-2)", "sh-hover": "0 7px 0 var(--line-2)",
      "lit": "inset 0 1px 0 rgba(255,253,248,.14)", "sh-stk": "2px 4px 0 rgba(40,30,15,.13)"
    }
  },
  "aliases": {
    "$comment": "shadcn semantic aliases (theme-independent — they reference the vars above). Restyle shadcn primitives through these (§3.6).",
    "background": "var(--paper)", "foreground": "var(--ink)",
    "card-bg": "var(--card)", "card-foreground": "var(--ink)",
    "popover": "var(--card)", "popover-foreground": "var(--ink)",
    "primary": "var(--red)", "primary-foreground": "#fff",
    "secondary": "var(--paper-2)", "secondary-foreground": "var(--ink)",
    "muted-foreground": "var(--muted)", "accent": "var(--elev)", "accent-foreground": "var(--ink)",
    "destructive": "var(--red)", "destructive-foreground": "#fff",
    "border": "var(--line-2)", "input": "var(--line-2)", "ring": "var(--red)"
  },
  "radius": { "sm": "8px", "md": "14px", "lg": "20px", "pill": "999px", "default": "0.875rem" },
  "fonts": {
    "display": "\"bc-alphapipe\", \"Archivo\", sans-serif",
    "sans": "\"Hanken Grotesk\", system-ui, sans-serif",
    "hand": "\"Kalam\", cursive",
    "mono": "\"Geist Mono\", ui-monospace, monospace"
  },
  "themeColors": [
    "paper", "paper-2", "card", "elev", "ink", "ink-2", "muted", "faint", "line", "line-2",
    "red", "ok", "warn", "rep", "t-out",
    "amber", "blue", "green", "purple", "coral", "teal", "pink", "lime", "dark", "link"
  ],
  "typeScale": {
    "$comment": "px — marketing display (§5.1) + app functional ramp (§5.5). 11px floor; reading-body >= 16.",
    "display-xl": 72, "display-l": 44, "display-m": 30, "eyebrow": 17,
    "app-page-title": 24, "app-section-header": 18, "app-card-title": 15,
    "app-reading-body": 16, "app-ui-text": 14, "app-table-cell": 13.5, "app-caption": 12, "app-badge": 11
  },
  "avatarOrder": ["blue", "amber", "green", "purple", "coral", "teal", "pink", "lime"],
  "datavizOrder": ["blue", "amber", "green", "purple", "coral", "teal", "pink", "lime"],
  "rules": {
    "oneAccent": "red = primary action + active/live + alerts only; never a module/avatar/chart-series colour",
    "noGradients": true,
    "lightPopsMax": 3,
    "statusRequiresLabel": true,
    "minFontPx": 11,
    "readingBodyMinPx": 16,
    "onFillLabel": "text on a categorical fill is theme-aware: --dark on dark, white on light except amber/lime (§3.7)"
  }
}
